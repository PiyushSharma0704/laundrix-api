{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "baseUrl": "./src",

    "paths": {
      "@/*": ["*"]
    },
    "typeRoots": ["./node_modules/@types", "./src/types"],
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}
