generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_SUPER_ADMIN
  PLATFORM_ADMIN
  PLATFORM_SUPPORT

  BUSINESS_OWNER

  STORE_MANAGER
  CASHIER
  DRIVER
  STAFF
}

model Business {
  id String @id @default(uuid())

  name String
  slug String @unique

  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id])

  currencyCode String  @default("INR")
  gstNumber    String?

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  stores Store[]

  garmentCategories GarmentCategory[]
  garmentTypes      GarmentType[]

  serviceTypes ServiceType[]

  serviceCatalogItems ServiceCatalogItem[]
}

model Store {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name String

  slug String

  code String

  phone String?
  email String?

  address String?

  customerSequence Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employees StoreEmployee[]
  customers CustomerStore[]

  @@unique([businessId, slug])
  @@unique([businessId, code])
  @@index([businessId])
}

model User {
  id String @id @default(uuid())

  email        String @unique
  passwordHash String

  refreshToken String?

  firstName String?
  lastName  String?

  role UserRole

  isActive Boolean @default(true)

  business Business?

  storeAccess StoreEmployee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreEmployee {
  id String @id @default(uuid())

  storeId String
  userId  String

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  role UserRole

  isActive Boolean @default(true)

  assignedAt DateTime  @default(now())
  removedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, userId])
  @@index([storeId])
  @@index([userId])
  @@index([isActive])
}

model Customer {
  id String @id @default(uuid())

  firstName String
  lastName  String?

  phone    String
  dialCode String @default("+91")

  email String?

  notes String?

  isActive Boolean @default(true)

  stores CustomerStore[]

  addresses Address[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phone, dialCode])
}

model Address {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  label String?

  buildingName String?
  landmark     String?
  locality     String?

  city  String?
  state String?

  pincode     String?
  countryCode String? @default("IN")

  isDefault Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([customerId])
}

model CustomerStore {
  customerId String
  storeId    String

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  customerCode String?

  createdAt DateTime @default(now())

  @@id([customerId, storeId])
  @@unique([storeId, customerCode])
  @@index([storeId])
}

enum PricingUnit {
  PIECE
  KG
  SQ_FT
}

model GarmentCategory {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  code String?

  name String

  description String?

  imageUrl String?

  sortOrder Int @default(0)

  isActive Boolean @default(true)

  garments GarmentType[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([businessId, name])
  @@index([businessId])
}

model GarmentType {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  categoryId String
  category   GarmentCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  code String?

  name String

  description String?

  imageUrl String?

  sortOrder Int @default(0)

  isActive Boolean @default(true)

  catalogItems ServiceCatalogItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([businessId, categoryId, name])
  @@index([businessId])
  @@index([categoryId])
}

model ServiceType {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  code       String?

  name String

  description String?

  imageUrl String?

  sortOrder Int @default(0)

  isActive Boolean @default(true)

  catalogItems ServiceCatalogItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([businessId, name])
  @@index([businessId])
}

model ServiceCatalogItem {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  serviceTypeId String
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id])

  garmentTypeId String
  garmentType   GarmentType @relation(fields: [garmentTypeId], references: [id])

  code String?

  description String?

  pricingUnit PricingUnit @default(PIECE)

  basePrice Decimal @db.Decimal(10, 2)

  minimumPrice Decimal? @db.Decimal(10, 2)

  gstRate Decimal? @db.Decimal(5, 2)

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([businessId, serviceTypeId, garmentTypeId])
  @@index([businessId, serviceTypeId, garmentTypeId, isActive])
  @@index([businessId])
}
